# ============================================
# Tenant API 環境變數範例
# 多租戶共用部署架構 - 不再需要 TENANT_SLUG
# ============================================

# 環境設定
NODE_ENV=development

# ============================================
# 資料庫配置（用於所有租戶）
# ============================================
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=postgres

# ============================================
# API 端口
# ============================================
TENANT_API_PORT=3001

# ============================================
# JWT 配置
# ============================================
JWT_ACCESS_SECRET=dev-tenant-access-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-tenant-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# 加密密鑰（32 字節 = 64 個十六進制字符）
# ============================================
ENCRYPTION_KEY=your-encryption-key-64-hex-chars

# ============================================
# CORS 配置
# ============================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ============================================
# Redis 配置（可選，開發環境不需要）
# ============================================
# REDIS_URL=redis://localhost:6379

# ============================================
# TRON 區塊鏈配置
# ============================================
TRON_NETWORK=testnet
TRON_USDT_TOKEN_ADDRESS_TESTNET=TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf
TRON_USDT_TOKEN_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
CONTRACT_EXECUTION_WALLET_ADDRESS=your-wallet-address
CONTRACT_EXECUTION_WALLET_PRIVATE_KEY=your-private-key
