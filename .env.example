# ================================
# Platform API 環境變數
# ================================
PLATFORM_API_PORT=3000

# PostgreSQL 配置（本地開發）
PLATFORM_DB_HOST=localhost
PLATFORM_DB_PORT=5432
PLATFORM_DB_NAME=saas_platform
PLATFORM_DB_USER=postgres
PLATFORM_DB_PASSWORD=postgres

# PostgreSQL 配置（生產環境 - 可選）
# PLATFORM_DB_HOST=your-rds-endpoint.amazonaws.com
# PLATFORM_DB_PORT=5432
# PLATFORM_DB_NAME=saas_platform_prod
# PLATFORM_DB_USER=your_user
# PLATFORM_DB_PASSWORD=your_password
# PLATFORM_DB_SSL=true

PLATFORM_JWT_SECRET=your-platform-jwt-secret
PLATFORM_REDIS_URL=redis://localhost:6379

# ================================
# Tenant API 環境變數（模板）
# ================================
TENANT_API_PORT=3001

# PostgreSQL 配置（本地開發）- 會自動加上 tenant ID
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_NAME=tenant
TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=postgres

TENANT_JWT_SECRET=your-tenant-jwt-secret
TENANT_ID=default-tenant-id
TENANT_REDIS_URL=redis://localhost:6379

# ================================
# Platform Admin 環境變數
# ================================
VITE_PLATFORM_API_URL=http://localhost:3000
VITE_APP_NAME=Platform Admin
VITE_APP_ENV=development

# ================================
# Tenant Admin 環境變數
# ================================
VITE_TENANT_API_URL=http://localhost:3001
VITE_APP_NAME=Tenant Admin
VITE_APP_ENV=development
VITE_TENANT_ID=

# ================================
# Agent Portal 環境變數
# ================================
VITE_TENANT_API_URL=http://localhost:3001
VITE_APP_NAME=Agent Portal
VITE_APP_ENV=development
VITE_TENANT_ID=

# ================================
# Customer Web 環境變數
# ================================
# Customer Web 運行於 port 3002
NEXT_PUBLIC_TENANT_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Customer Web
NEXT_PUBLIC_TENANT_ID=

# ================================
# 共享環境變數
# ================================
# AWS / Cloud Provider
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Payment Gateway
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Analytics
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=

# Feature Flags
ENABLE_MULTI_LEVEL_AGENTS=true
ENABLE_WHITE_LABEL=true
ENABLE_CUSTOM_DOMAIN=true

# ================================
# TRON 區塊鏈配置
# ================================
# 網路設定：testnet (Nile) / shasta / mainnet
TRON_NETWORK=testnet

# USDT 合約地址
TRON_USDT_TOKEN_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_USDT_TOKEN_ADDRESS_TESTNET=TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf

# 合約執行錢包
CONTRACT_EXECUTION_WALLET_ADDRESS=
